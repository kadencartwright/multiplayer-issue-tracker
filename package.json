{
	"name": "multiplayer-issue-tracker",
	"version": "1.0.0",
	"description": "Local-first multiplayer issue tracker built with TanStack Start, Convex, RustFS, and MCP.",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"check": "turbo check",
		"dev": "docker compose up -d rustfs && pnpm --filter web exec convex dev --start 'pnpm --filter web dev'",
		"format": "biome format --write .",
		"lint": "biome check .",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"fallow": "fallow --only dead-code,dupes,health --summary",
		"prepare": "lefthook install"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"packageManager": "pnpm@10.28.1",
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"fallow": "^2.80.0",
		"lefthook": "^2.1.8",
		"turbo": "^2.9.14",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lefthook",
			"lightningcss"
		]
	}
}
